rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── kits collection ───────────────────────────────────────────────────
    // Public can READ kit metadata (needed by search widget).
    // Only Firebase Functions (Admin SDK) can WRITE.
    match /kits/{kitId} {
      allow read: if true;          // search widget reads this
      allow write: if false;        // only Firebase Function writes via Admin SDK
    }

    // ── kit_slots collection (PRIVATE) ────────────────────────────────────
    // The full per-slide capacity map. Read ONLY by the fit_content callable
    // via the Admin SDK (which bypasses these rules). Never readable by the
    // client — this keeps the matching/capacity logic off the browser.
    match /kit_slots/{kitId} {
      allow read: if false;
      allow write: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
