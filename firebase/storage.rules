rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Admin upload area ─────────────────────────────────────────────────
    // The admin (logged in as lazydogtemplates@gmail.com) may upload the
    // _SYSTEM.pdf + .slots.json into kits/. The Cloud Function (Admin SDK)
    // still does all the processing; this only lets the admin's own browser
    // drop the file in. Nobody else can write here.
    match /kits/{allPaths=**} {
      allow write: if request.auth != null
                   && request.auth.token.email == 'lazydogtemplates@gmail.com';
      allow read: if false;
    }

    // ── Editor templates (free) : public read, admin-only upload ──────────
    // The Template Upload page (admin) drops the parsed design JSON here;
    // the editor's Templates panel reads it for every visitor.
    match /editor_templates/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email in [
                        'javed5395@gmail.com',
                        'lazydogtemplates@gmail.com'
                      ];
    }

    // ── Everything else: server-side (Admin SDK) only ─────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
