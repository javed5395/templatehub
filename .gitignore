# --- Keep these OFF the public website (GitHub Pages serves everything else) ---

# Admin panel: contains the admin password + Cloudinary secret. Run it locally only.
admin_panel.html

# Backend source (Google Apps Script). Lives in the Apps Script editor, not the site.
*.gs

# Metadata codec — PRIVATE. Never expose field/value codes to public.
# This file is the secret key to the LazyDog metadata encoding system.
meta_codec.py
firebase/functions/meta_codec.py

# Compiled Python — bytecode of the private files leaks the same secrets!
__pycache__/
*.pyc

# FULL editor source (parser+writer+all) — THE BRAIN. Never ever public.
editor_test.html

# User data export — private
firebase/users.json

# Backend function source — deploys via `firebase deploy`, git never needs it.
firebase/functions/main.py
firebase/functions/venv/

# Common local-only / sensitive files
*.bak
*.tmp
.env
.DS_Store
Thumbs.db

# --- Buyer autofill system — PRIVATE brain/heart, never expose on the public site ---
fit_engine.js
buyer_flow_test.html
editor_opus.html
content_fitter.py

# AI cascade — private, deploy to Firebase but never GitHub
ai_fill.py
firebase/functions/ai_fill.py

# Word source of va_dictionary.js — reference only, keep off public site
va_dictionary.docx
